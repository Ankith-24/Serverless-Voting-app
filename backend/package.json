{
  "name": "student-voting-backend",
  "version": "1.0.0",
  "description": "Serverless backend for Student Voting System",
  "type": "module",
  "scripts": {
    "dynamo": "java -Djava.library.path=./.dynamodb/DynamoDBLocal_lib -jar ./.dynamodb/DynamoDBLocal.jar -port 8000 -inMemory -sharedDb",
    "setup-db": "node src/setup-db.js",
    "start": "npx serverless offline start",
    "deploy": "npx serverless deploy",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "serverless": "^3.39.0",
    "serverless-offline": "^13.8.0",
    "vitest": "^3.2.6"
  }
}
